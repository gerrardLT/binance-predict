# LLM
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DECISION_MODEL=deepseek-v4-pro
REVIEW_MODEL=qwen3.7-max

# 数据库（Docker 部署时 compose 读取这三个变量初始化 DB + 构建 DATABASE_URL）
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=binance_predict
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/binance_predict

# Binance 行情
BINANCE_SPOT_WS_URL=wss://stream.binance.com:9443/ws
SYMBOL=BTCUSDT
HORIZON=5m
NOISE_THRESHOLD=0.0005
CONFIDENCE_STRONG=0.75
CONFIDENCE_NORMAL=0.60
CONFIDENCE_WEAK=0.50

# 服务
API_PORT=8000
LOG_LEVEL=INFO

# 安全
# CORS 允许的前端源（逗号分隔），空值默认允许 localhost 开发源
# 生产环境示例: CORS_ALLOWED_ORIGINS=https://predict.example.com,http://your-bt-domain.com
CORS_ALLOWED_ORIGINS=
# API Bearer Token 认证密钥，空值时禁用认证（仅开发环境）
API_AUTH_TOKEN=

# 交易
BINANCE_API_KEY=
BINANCE_API_SECRET=
PREDICTION_TRADE_AMOUNT_USDT=2.0
PREDICTION_WALLET_ADDRESS=
PREDICTION_WALLET_ID=
AGENT_AUTO_TRADE=false
