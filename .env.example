# LLM
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DECISION_MODEL=deepseek-v4-pro
REVIEW_MODEL=qwen3.7-max

# 数据库（Docker 部署时 compose 读取这三个变量初始化 DB + 构建 DATABASE_URL）
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=binance_predict
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/binance_predict

# Binance 行情
BINANCE_SPOT_WS_URL=wss://stream.binance.com:9443/ws
SYMBOL=BTCUSDT
HORIZON=5m
NOISE_THRESHOLD=0.0005
CONFIDENCE_STRONG=0.75
CONFIDENCE_NORMAL=0.60
CONFIDENCE_WEAK=0.50

# 服务
API_PORT=8000
LOG_LEVEL=INFO

# 安全
# CORS 允许的前端源（逗号分隔），空值默认允许 localhost 开发源
# 生产环境示例: CORS_ALLOWED_ORIGINS=https://predict.example.com,http://your-bt-domain.com
CORS_ALLOWED_ORIGINS=
# API Bearer Token 认证密钥，空值时禁用认证（仅开发环境）
API_AUTH_TOKEN=

# 交易
BINANCE_API_KEY=
BINANCE_API_SECRET=
PREDICTION_TRADE_AMOUNT_USDT=2.0
PREDICTION_WALLET_ADDRESS=
PREDICTION_WALLET_ID=
AGENT_AUTO_TRADE=false

# Agent 运行健康监控 / 告警（邮件为主渠道）
# 告警邮件总开关：true 时非 OK 状态且有新告警会发邮件
AGENT_ALERT_EMAIL_ENABLED=false
# SMTP 服务器（587=STARTTLS；465 SSL 需将 USE_TLS 置 false 并自行适配）
AGENT_ALERT_SMTP_HOST=
AGENT_ALERT_SMTP_PORT=587
# 登录凭据（多数邮箱用「授权码」而非登录密码）
AGENT_ALERT_SMTP_USER=
AGENT_ALERT_SMTP_PASSWORD=
AGENT_ALERT_SMTP_USE_TLS=true
# 发件人（留空回退到 SMTP_USER）与收件人（逗号分隔，可多个）
AGENT_ALERT_EMAIL_FROM=
AGENT_ALERT_EMAIL_TO=
# 同一告警 code 的去重抑制窗口（秒），默认 900=15 分钟
AGENT_ALERT_SUPPRESS_SECONDS=900
# 可选备用渠道：通用 JSON webhook（留空禁用）
AGENT_ALERT_WEBHOOK_URL=
# 健康快照保留天数（超期自动清理）
AGENT_HEALTH_SNAPSHOT_RETENTION_DAYS=7
